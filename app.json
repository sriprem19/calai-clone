{
  "expo": {
    "name": "CalAI Clone",
    "slug": "calai-clone",
    "scheme": "calaiclone",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.calaiclone.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0a"
      },
      "package": "com.calaiclone.app"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow CalAI Clone to access your camera to photograph meals."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow CalAI Clone to access your photos to log meals."
        }
      ],
      "expo-image",
      "expo-localization",
      "expo-secure-store",
      "expo-web-browser",
      "@sentry/react-native"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
